    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "firebase": "^12.10.0",
    "lucide-react": "^0.468.0",
    "marked": "^17.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.0.0",
